# Demo GIF for the README hero. Run `bash assets/demo-setup.sh` first to stage
# the demo repo + transcript, then record from the repo root:
#
#   vhs assets/demo.tape
#
# Clean up after: rm -rf ~/code/shipit ~/.claude/projects/-Users-keen-code-shipit

Output assets/demo.gif

Set FontSize 12
Set Width 1040
Set Height 520
Set Padding 16
Set TypingSpeed 75ms

Hide
Type `export PATH="$PWD/target/release:$PATH" && cd ~/code/shipit && clear`
Enter
Sleep 1s
Show

Sleep 1s
Type "wdyd"
Sleep 600ms
Enter
Sleep 12s
